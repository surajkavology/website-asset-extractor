# Port the Express server listens on.
# Railway/Render inject this automatically — do not set it manually there.
PORT=5000

# Comma-separated list of allowed frontend origins (no trailing slash).
# Set to your actual Vercel URL on Railway/Render.
ALLOWED_ORIGINS=https://your-project.vercel.app

# Set to "true" ONLY on hosts with ≥ 512 MB free RAM (Railway Starter, Render Starter+).
# Leave unset or set to "false" on Render Free — all other features still work.
# Also requires: npx playwright install chromium --with-deps in the build command.
ENABLE_SCREENSHOTS=false
